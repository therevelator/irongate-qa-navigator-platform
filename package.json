{
  "name": "irongate-qa-navigator",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise-grade Quality Assurance Intelligence Platform",
  "license": "UNLICENSED",
  "author": "IronGate Software LTD",
  "copyright": "Copyright (c) 2025 IronGate Software LTD. All rights reserved.",
  "type": "module",
  "scripts": {
    "start": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run server\" \"npm run dev\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "server:prod": "tsx server/index.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "jest --config jest.config.cjs",
    "test:api": "jest --config jest.config.cjs tests/api",
    "test:db": "jest --config jest.config.cjs tests/database",
    "test:e2e": "playwright test auth-spa.spec.ts user-management-spa.spec.ts permissions-spa.spec.ts simple-test.spec.ts --project=chrome",
    "test:e2e:all": "playwright test auth-spa.spec.ts user-management-spa.spec.ts permissions-spa.spec.ts simple-test.spec.ts --project=chrome --headed --workers=1",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test auth-spa.spec.ts user-management-spa.spec.ts permissions-spa.spec.ts simple-test.spec.ts --project=chrome --headed --workers=1",
    "test:e2e:debug": "playwright test --debug",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:watch": "jest --config jest.config.cjs --watch",
    "playwright:install": "playwright install chromium",
    "playwright:report": "playwright show-report"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.554.0",
    "node-cron": "^4.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.4.1",
    "serverless-http": "^4.0.0",
    "sweetalert2": "^11.26.3",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "mysql2": "^3.15.3",
    "postcss": "^8.5.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.2"
  }
}
