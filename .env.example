# IronGate QA Navigator - Environment Variables
# Copy this file to .env and fill in your actual API credentials

# ============================================================================
# JENKINS CONFIGURATION
# ============================================================================
VITE_JENKINS_URL=https://jenkins.yourcompany.com
VITE_JENKINS_USER=your-username
VITE_JENKINS_TOKEN=your-api-token

# How to get Jenkins API token:
# 1. Log in to Jenkins
# 2. Click your name (top right) → Configure
# 3. API Token section → Add new Token
# 4. Copy the generated token

# ============================================================================
# JIRA CONFIGURATION
# ============================================================================
VITE_JIRA_URL=https://yourcompany.atlassian.net
VITE_JIRA_EMAIL=your-email@company.com
VITE_JIRA_TOKEN=your-api-token

# How to get Jira API token:
# 1. Go to https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Click "Create API token"
# 3. Give it a label and copy the token

# ============================================================================
# SONARQUBE CONFIGURATION
# ============================================================================
VITE_SONAR_URL=https://sonarqube.yourcompany.com
VITE_SONAR_TOKEN=your-user-token

# How to get SonarQube token:
# 1. Log in to SonarQube
# 2. My Account → Security
# 3. Generate Tokens → Enter name → Generate
# 4. Copy the token

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================
VITE_GITHUB_TOKEN=ghp_your_personal_access_token
VITE_GITHUB_ORG=your-organization

# How to get GitHub Personal Access Token:
# 1. GitHub Settings → Developer settings → Personal access tokens
# 2. Generate new token (classic)
# 3. Select scopes: repo, read:org, read:user
# 4. Generate and copy the token

# ============================================================================
# TESTRAIL CONFIGURATION
# ============================================================================
VITE_TESTRAIL_URL=https://yourcompany.testrail.io
VITE_TESTRAIL_EMAIL=your-email@company.com
VITE_TESTRAIL_KEY=your-api-key

# How to get TestRail API key:
# 1. Log in to TestRail
# 2. My Settings → API Keys
# 3. Add Key → Copy the key

# ============================================================================
# DATADOG CONFIGURATION
# ============================================================================
VITE_DATADOG_API_KEY=your-api-key
VITE_DATADOG_APP_KEY=your-application-key

# How to get Datadog keys:
# 1. Datadog → Organization Settings → API Keys
# 2. Create API key
# 3. Organization Settings → Application Keys
# 4. Create Application key

# ============================================================================
# NEW RELIC CONFIGURATION (Alternative to Datadog)
# ============================================================================
# VITE_NEWRELIC_API_KEY=your-api-key
# VITE_NEWRELIC_ACCOUNT_ID=your-account-id

# ============================================================================
# NOTES
# ============================================================================
# - Keep this file secure and never commit it to version control
# - The .env file is already in .gitignore
# - All variables are prefixed with VITE_ to be accessible in the frontend
# - Leave empty to use demo/mock data
